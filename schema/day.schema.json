{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chan7-2026/schema/day.schema.json",
  "title": "day-YYYY-MM-DD.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "dayIndex", "label", "participants", "sections"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "dayIndex": { "type": "integer", "minimum": 1 },
    "label": { "type": "string", "minLength": 1 },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "fahui",
          "fawei",
          "attendant",
          "server",
          "duty",
          "volunteer",
          "all",
          "other"
        ]
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Section" }
    }
  },
  "definitions": {
    "Section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "timePoints"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "timePoints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/TimePoint" }
        }
      }
    },
    "TimePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "time",
        "isBellRow",
        "periodLabel",
        "leadMinutesOverride",
        "tasks"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "time": { "$ref": "#/definitions/Time" },
        "isBellRow": { "type": "boolean" },
        "periodLabel": { "type": ["string", "null"] },
        "leadMinutesOverride": { "type": ["integer", "null"], "minimum": 0 },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Task" }
        }
      }
    },
    "Time": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value",
        "rangeEnd",
        "raw",
        "anchorTimePointId",
        "offsetMinutes"
      ],
      "properties": {
        "kind": { "type": "string", "enum": ["exact", "range", "fuzzy"] },
        "value": {
          "type": ["string", "null"],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "rangeEnd": {
          "type": ["string", "null"],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "raw": { "type": "string" },
        "anchorTimePointId": { "type": ["string", "null"] },
        "offsetMinutes": { "type": ["integer", "null"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "exact" } }
          },
          "then": {
            "properties": {
              "value": { "type": "string" },
              "rangeEnd": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "range" } }
          },
          "then": {
            "properties": {
              "value": { "type": "string" },
              "rangeEnd": { "type": "string" }
            }
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "fuzzy" } }
          },
          "then": {
            "properties": {
              "value": { "type": "null" },
              "rangeEnd": { "type": "null" }
            }
          }
        }
      ]
    },
    "Task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "action", "templateRef", "owners", "ownerRaw", "signal", "note"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "templateRef": { "type": ["string", "null"] },
        "owners": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "fahui",
              "fawei",
              "attendant",
              "server",
              "duty",
              "volunteer",
              "all",
              "other"
            ]
          }
        },
        "ownerRaw": { "type": "string" },
        "signal": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] }
      }
    }
  }
}
